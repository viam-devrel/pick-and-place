{
  "modules": [
    {
      "type": "registry",
      "name": "viam_ufactory",
      "module_id": "viam:ufactory",
      "version": "latest"
    },
    {
      "type": "registry",
      "name": "viam_realsense",
      "module_id": "viam:realsense",
      "version": "latest"
    },
    {
      "type": "registry",
      "name": "devrel_shape-finder",
      "module_id": "devrel:shape-finder",
      "version": "latest"
    },
    {
      "type": "registry",
      "name": "erh_vmodutils",
      "module_id": "erh:vmodutils",
      "version": "latest"
    }
  ],
  "components": [
    {
      "name": "arm-1",
      "api": "rdk:component:arm",
      "model": "viam:ufactory:xArm6",
      "attributes": {
        "host": "REPLACE_WITH_ARM_IP",
        "speed_degs_per_sec": 30
      },
      "frame": {
        "parent": "world",
        "translation": { "x": 0, "y": 0, "z": 0 },
        "orientation": {
          "type": "ov_degrees",
          "value": { "x": 0, "y": 0, "z": 1, "th": 0 }
        }
      }
    },
    {
      "name": "gripper-1",
      "api": "rdk:component:gripper",
      "model": "viam:ufactory:gripper",
      "attributes": {
        "arm": "arm-1"
      },
      "frame": {
        "parent": "arm-1",
        "translation": { "x": 0, "y": 0, "z": 105 },
        "orientation": {
          "type": "ov_degrees",
          "value": { "x": 0, "y": 0, "z": 1, "th": 0 }
        }
      },
      "depends_on": ["arm-1"]
    },
    {
      "name": "cam-1",
      "api": "rdk:component:camera",
      "model": "viam:camera:realsense",
      "attributes": {
        "sensors": ["color", "depth"],
        "align_color_depth": true,
        "serial_number": "REPLACE_WITH_CAMERA_SERIAL"
      },
      "frame": {
        "parent": "arm-1",
        "translation": { "x": -73, "y": 40, "z": 18 },
        "orientation": {
          "type": "ov_degrees",
          "value": { "x": 0, "y": 0, "z": 1, "th": 270 }
        }
      }
    },

    {
      "name": "home-pose",
      "api": "rdk:component:switch",
      "model": "erh:vmodutils:arm-position-saver",
      "attributes": { "arm": "arm-1" },
      "depends_on": ["arm-1"]
    },
    {
      "name": "approach-pose",
      "api": "rdk:component:switch",
      "model": "erh:vmodutils:arm-position-saver",
      "attributes": { "arm": "arm-1" },
      "depends_on": ["arm-1"]
    },
    {
      "name": "grasp-pose",
      "api": "rdk:component:switch",
      "model": "erh:vmodutils:arm-position-saver",
      "attributes": { "arm": "arm-1" },
      "depends_on": ["arm-1"]
    },
    {
      "name": "travel-pose",
      "api": "rdk:component:switch",
      "model": "erh:vmodutils:arm-position-saver",
      "attributes": { "arm": "arm-1" },
      "depends_on": ["arm-1"]
    },
    {
      "name": "place-pose",
      "api": "rdk:component:switch",
      "model": "erh:vmodutils:arm-position-saver",
      "attributes": { "arm": "arm-1" },
      "depends_on": ["arm-1"]
    }
  ],
  "services": [
    {
      "name": "shape-detector",
      "api": "rdk:service:vision",
      "model": "devrel:shape-finder:detector",
      "attributes": {
        "camera_name": "cam-1"
      },
      "depends_on": ["cam-1"]
    },
    {
      "name": "vision-segment",
      "api": "rdk:service:vision",
      "model": "viam:vision:detections-to-segments",
      "attributes": {
        "detector_name": "shape-detector",
        "confidence_threshold_pct": 0.5,
        "mean_k": 50,
        "sigma": 1.5
      },
      "depends_on": ["shape-detector"]
    }
  ]
}
